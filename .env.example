# ═══════════════════════════════════════════════════
# AlphaDesk — Environment Variables
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────
# These must be set or the system won't start.

# Anthropic (powers all Claude Opus 4.6 analysis)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key

# Telegram Bot (delivers daily briefs to your phone)
# Create bot: https://t.me/BotFather → /newbot
# Get chat ID: send any message to your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── NEWS & MARKET DATA ───────────────────────────
# At least one news source recommended for full coverage.

# Finnhub (company news per ticker)
# Free tier: 60 calls/min
# Get key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key

# NewsAPI (market headlines + business news)
# Free tier: 100 calls/day
# Get key: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key

# ── ADVISOR LAYER (new) ──────────────────────────

# FRED (Federal Reserve Economic Data — macro indicators)
# Powers: interest rates, yield curve, inflation, unemployment
# Free: unlimited calls
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key

# Financial Modeling Prep (earnings call transcripts + guidance)
# Powers: earnings analysis, management quotes, cross-company mentions
# Free tier: 250 calls/day (enough for daily runs)
# Get key: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_key

# Kalshi (prediction market data — crowd sentiment)
# Powers: Fed rate cut odds, recession probability, policy outcomes
# Optional — Polymarket (the other source) needs no key
# Get key: https://kalshi.com/sign-up (API access in account settings)
KALSHI_API_KEY=your_kalshi_key

# ── OPTIONAL ──────────────────────────────────────

# Daily API spend cap in USD (default: $20)
# When exceeded, Opus synthesis is skipped and raw data is delivered instead.
DAILY_COST_CAP=20.00
